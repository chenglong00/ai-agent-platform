# App name in the dashboard sidebar header (optional; default "Acme Inc." if unset).
# NEXT_PUBLIC_APP_NAME=

# Leave unset/commented → same-origin /api/v1/* (proxied by app/api/v1/[...path] to FastAPI; no browser CORS).
# Server-only: target for that proxy (default http://127.0.0.1:8000). Docker Compose sets http://api:8000.
# BACKEND_PROXY_TARGET=http://127.0.0.1:8000
# Uncomment only if the browser must call the API host directly:
# NEXT_PUBLIC_API_URL=

# Optional overrides if your API uses different paths:
# NEXT_PUBLIC_AUTH_TOKEN_PATH=/api/v1/auth/token
# NEXT_PUBLIC_AUTH_ME_PATH=/api/v1/auth/me

# Set to "true" to use dummy login (any email/password). Omit or "false" to use real API.
# NEXT_PUBLIC_USE_DUMMY_AUTH=
