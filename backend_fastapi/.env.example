# Environment Configuration
APP_ENV=

# Application Settings
APPLICATION_NAME="AI Application Platform"
VERSION=1.0.0
DESCRIPTION="AI Application Platform"

LOG_LEVEL=DEBUG
LOG_DIR=./logs
TIMEZONE=Asia/Singapore

ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DATABASE_URL=
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# MongoDB (optional — docker compose up -d mongodb)
MONGODB_URI=

# Knowledge base RAG (agent search_knowledge_base tool)
KNOWLEDGE_BASE_RAG_ENABLED=true
KNOWLEDGE_BASE_RAG_TOP_K=5
KNOWLEDGE_BASE_RAG_MIN_SCORE=0.45
KNOWLEDGE_BASE_RAG_MAX_CHUNKS_SCAN=2000

# Gemini PDF parsing (knowledge base upload)
KNOWLEDGE_BASE_GEMINI_PARSING_ENABLED=true
KNOWLEDGE_BASE_GEMINI_PARSING_BATCH_PAGES=10

# Deep agent skills (app/ai/skills/*/SKILL.md)
DEEP_AGENT_SKILLS_ENABLED=true

# Long-term user memory (Postgres user_memories)
USER_MEMORY_ENABLED=true
USER_MEMORY_PROMPT_MAX_ITEMS=20

# Scheduled workflows (Postgres workflows table)
WORKFLOW_SCHEDULER_ENABLED=true
WORKFLOW_SCHEDULER_POLL_SECONDS=60

SECRET_KEY=

INITIAL_OWNER_EMAIL=
INITIAL_OWNER_PASSWORD=
INITIAL_OWNER_NAME=


# Google Cloud Platform Integration
GCP_PROJECT_ID=
GCP_INTEGRATION_REGION=
GCP_TRIGGER_ID=
GOOGLE_API_KEY=

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
# Set AUTH_COOKIE_SECURE=true in production (HTTPS only)
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# Google OAuth2 (optional). If set, GET /oauth/google and /oauth/google/callback are enabled.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Use the Next.js proxy in dev so auth cookies are on localhost:3000:
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/oauth/google/callback
GOOGLE_REDIRECT_URI=""
# Where to redirect after Google login (auth cookies are set on the callback response)
AUTH_SUCCESS_REDIRECT_URL=http://localhost:3000/dashboard
# Extra Google OAuth scopes (space-separated). e.g. "https://www.googleapis.com/auth/calendar.readonly" for Calendar. Base "openid email profile" are always included.
GOOGLE_EXTRA_SCOPES=""

# Enterprise connectors (Google Workspace official MCP servers)
CONNECTORS_ENABLED=true
# Add this redirect URI in Google Cloud Console alongside login OAuth URIs
CONNECTOR_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/connectors/oauth/callback
CONNECTOR_SUCCESS_REDIRECT_URL=http://localhost:3000/connector

# Encrypt OAuth tokens at rest (optional but recommended). 32+ char passphrase or Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=


# Frontend (for OAuth redirect after Google/Microsoft login)
FRONTEND_URL=

# Deep agent sandbox backend: local | daytona | modal
DEEP_AGENT_BACKEND=local
# Remote (daytona/modal): /home/{user_slug}/ + /home/{user_slug}/workspace/
DEEP_AGENT_SANDBOX_HOME_ROOT=/home
DEEP_AGENT_SANDBOX_WORKSPACE_DIR=workspace
# Host path for per-user homes when DEEP_AGENT_BACKEND=local (workspace = {home}/workspace/)
DEEP_AGENT_SANDBOX_LOCAL_ROOT=data/agent_sandboxes
# Idle TTL (seconds) before an unused user sandbox is released; 0 disables cleanup
DEEP_AGENT_SANDBOX_IDLE_TTL_SECONDS=3600
DEEP_AGENT_SANDBOX_CLEANUP_INTERVAL_SECONDS=300

# Playwright browser tools (per-user Chromium; run: uv run playwright install chromium)
BROWSER_PLAYWRIGHT_ENABLED=false
BROWSER_PLAYWRIGHT_HEADLESS=true
BROWSER_PLAYWRIGHT_TIMEOUT_MS=30000
BROWSER_PLAYWRIGHT_IDLE_TTL_SECONDS=1800
BROWSER_PLAYWRIGHT_LIVE_ENABLED=true
BROWSER_PLAYWRIGHT_LIVE_MAX_FPS=12
BROWSER_PLAYWRIGHT_LIVE_JPEG_QUALITY=65

# Daytona (when DEEP_AGENT_BACKEND=daytona) — ONE shared VM; users isolated by folder
DAYTONA_API_KEY=
DAYTONA_TARGET=us
# DAYTONA_API_URL=https://app.daytona.io/api
# Optional: reuse an existing sandbox id instead of creating a new VM
# DAYTONA_SANDBOX_ID=
# Keep false in dev so uvicorn --reload does not wipe the shared VM.
DAYTONA_DELETE_ON_SHUTDOWN=false
# Auto-start stopped sandboxes; idle auto-stop for new VMs (minutes, 0=never)
DAYTONA_START_TIMEOUT_SECONDS=120
DAYTONA_AUTO_STOP_MINUTES=120
# Cleanup old VMs: uv run python scripts/cleanup_daytona_sandboxes.py

# Modal (when DEEP_AGENT_BACKEND=modal)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
DEEP_AGENT_MODAL_APP=ai-application-platform-deep-agent

# Langfuse LLM tracing (optional — enabled when all three are set)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# EU: https://cloud.langfuse.com | US: https://us.cloud.langfuse.com
LANGFUSE_BASE_URL=
