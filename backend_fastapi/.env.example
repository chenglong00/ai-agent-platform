# Environment Configuration
APP_ENV=

# Application Settings
APPLICATION_NAME="AI Application Platform"
VERSION=1.0.0
DESCRIPTION="AI Application Platform"

LOG_LEVEL=DEBUG
LOG_DIR=./logs
TIMEZONE=Asia/Singapore

ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

DATABASE_URL=
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# MongoDB (optional — docker compose up -d mongodb)
MONGODB_URI=

SECRET_KEY=

INITIAL_OWNER_EMAIL=
INITIAL_OWNER_PASSWORD=
INITIAL_OWNER_NAME=


# Google Cloud Platform Integration
GCP_PROJECT_ID=
GCP_INTEGRATION_REGION=
GCP_TRIGGER_ID=
GOOGLE_API_KEY=

# Google OAuth2 (optional). If set, GET /oauth/google/authorize and /oauth/google/callback are enabled.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Must match the redirect URI in Google Cloud Console (e.g. http://localhost:8000/api/v1/oauth/google/callback)
GOOGLE_REDIRECT_URI==""
# Where to redirect the user after successful Google login (e.g. http://localhost:3000/login/callback). Token is appended as ?token=...
AUTH_SUCCESS_REDIRECT_URL=""
# Extra Google OAuth scopes (space-separated). e.g. "https://www.googleapis.com/auth/calendar.readonly" for Calendar. Base "openid email profile" are always included.
GOOGLE_EXTRA_SCOPES=""

# Encrypt OAuth tokens at rest (optional but recommended). 32+ char passphrase or Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=


# Frontend (for OAuth redirect after Google/Microsoft login)
FRONTEND_URL=

# Deep agent sandbox backend: local | daytona | modal
DEEP_AGENT_BACKEND=local
DEEP_AGENT_SANDBOX_WORKDIR=/workspace
# Host path for per-user workspaces when DEEP_AGENT_BACKEND=local
DEEP_AGENT_SANDBOX_LOCAL_ROOT=data/agent_sandboxes
# Idle TTL (seconds) before an unused user sandbox is released; 0 disables cleanup
DEEP_AGENT_SANDBOX_IDLE_TTL_SECONDS=3600
DEEP_AGENT_SANDBOX_CLEANUP_INTERVAL_SECONDS=300

# Playwright browser tools (per-user Chromium; run: uv run playwright install chromium)
BROWSER_PLAYWRIGHT_ENABLED=false
BROWSER_PLAYWRIGHT_HEADLESS=true
BROWSER_PLAYWRIGHT_TIMEOUT_MS=30000
BROWSER_PLAYWRIGHT_IDLE_TTL_SECONDS=1800

# Daytona (when DEEP_AGENT_BACKEND=daytona)
DAYTONA_API_KEY=
DAYTONA_TARGET=us
# DAYTONA_API_URL=https://app.daytona.io/api

# Modal (when DEEP_AGENT_BACKEND=modal)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
DEEP_AGENT_MODAL_APP=ai-application-platform-deep-agent
